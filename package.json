{
  "name": "ecommerce",
  "private": true,
  "scripts": {
    "build": "bunx turbo run build",
    "dev": "bunx turbo run dev",
    "dev:setup": "cd packages/product-db && bun run db:generate && cd ../.. && bun dev",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write",
    "check-types": "bunx turbo run check-types && bunx tsc -p tsconfig.tests.json --noEmit",
    "audit": "bun audit --audit-level=moderate --ignore=GHSA-v3rj-xjv7-4jmq --ignore=GHSA-3v7f-55p6-f55p --ignore=GHSA-c2c7-rcm5-vvqj",
    "test": "bun test --preload ./tests/preload.ts",
    "verify": "bun run lint && bun run check-types && bun run test && bun run build",
    "knip": "knip"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "knip": "^6.3.0",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2"
  },
  "engines": {
    "bun": ">=1.3.11",
    "node": ">=20.9.0"
  },
  "packageManager": "bun@1.3.11",
  "overrides": {
    "@clerk/backend": "^3.2.4",
    "@hono/node-server": "^1.19.11",
    "effect": "^3.21.0",
    "hono": "^4.12.9",
    "lodash": "^4.17.23"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
