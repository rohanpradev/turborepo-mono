# ==========================================
# Clerk Authentication (Required)
# ==========================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here
# Local-only default credentials for ops routes: admin / local-dev
TRAEFIK_BASIC_AUTH_USERS=admin:$$apr1$$l2NjIjPT$$rpBpr/hrawWdK.VRWyKo3/
TRAEFIK_BASIC_AUTH_USERS_DOCKER=admin:$$apr1$$l2NjIjPT$$rpBpr/hrawWdK.VRWyKo3/

# ==========================================
# Stripe Payment (Required)
# ==========================================
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
STRIPE_WEBHOOK_URL=http://localhost:8002/api/webhooks/stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
# Optional override for the Docker Stripe CLI. Defaults to STRIPE_SECRET_KEY when unset.
STRIPE_API_KEY=your_stripe_secret_key_here
STRIPE_DEVICE_NAME=ecommerce-docker
STRIPE_WEBHOOK_FORWARD_TO=http://payment-service:8002/api/webhooks/stripe
STRIPE_CLI_EVENTS=checkout.session.completed,payment_intent.succeeded,payment_intent.payment_failed

# ==========================================
# Database URLs (Defaults for local dev)
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=product_db
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin123
MONGO_INITDB_DATABASE=order_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/product_db?schema=public
MONGO_URL=mongodb://admin:admin123@localhost:27017/order_db?authSource=admin
DOCKER_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/product_db?schema=public
DOCKER_MONGO_URL=mongodb://admin:admin123@mongodb:27017/order_db?authSource=admin

# ==========================================
# Kafka Brokers (Defaults for local dev)
# ==========================================
KAFKA_BROKERS=localhost:9094,localhost:9095,localhost:9096
DOCKER_KAFKA_BROKERS=kafka-broker-1:9092,kafka-broker-2:9092,kafka-broker-3:9092

# ==========================================
# Service URLs (Defaults for Docker/Traefik)
# ==========================================
CLIENT_APP_URL=https://shop.localhost
CORS_ALLOWED_ORIGINS=https://shop.localhost,https://admin.localhost,http://localhost:3002,http://localhost:3003
NEXT_PUBLIC_PRODUCT_SERVICE_URL=https://api.localhost
NEXT_PUBLIC_ORDER_SERVICE_URL=https://api.localhost
NEXT_PUBLIC_PAYMENT_SERVICE_URL=https://api.localhost
