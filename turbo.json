{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "MONGO_URL",
    "KAFKA_BROKERS",
    "DOCKER_DATABASE_URL",
    "DOCKER_MONGO_URL",
    "DOCKER_KAFKA_BROKERS",
    "PRODUCT_SERVICE_INTERNAL_URL",
    "ORDER_SERVICE_INTERNAL_URL",
    "PAYMENT_SERVICE_INTERNAL_URL",
    "NEXT_PUBLIC_PRODUCT_SERVICE_URL",
    "NEXT_PUBLIC_ORDER_SERVICE_URL",
    "NEXT_PUBLIC_PAYMENT_SERVICE_URL",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "CLERK_SECRET_KEY",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "CLIENT_APP_URL",
    "CORS_ALLOWED_ORIGINS"
  ],
  "tasks": {
    "//#lint": {},
    "//#lint:fix": {
      "cache": false
    },
    "//#knip": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build", "^db:generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": ["DATABASE_URL"]
    },
    "check-types": {
      "dependsOn": ["^check-types", "^db:generate"]
    },
    "dev": {
      "dependsOn": ["^db:generate"],
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:deploy": {
      "cache": false
    }
  }
}
